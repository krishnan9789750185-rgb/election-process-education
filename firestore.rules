rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Quiz scores: authenticated users can create, no public reads
    match /quiz_scores/{doc} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }

    // User progress: users can read/write their own data
    match /user_progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Simulator results: authenticated users can create
    match /simulator_results/{doc} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }

    // Leaderboard: anyone can read, only authenticated can write
    match /leaderboard/{doc} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Feedback: authenticated users can create
    match /feedback/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
